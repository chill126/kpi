rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isManagement() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'management';
    }

    function isSameSite(siteId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.siteId == siteId;
    }

    match /users/{uid} {
      allow read: if request.auth.uid == uid || isManagement();
      allow write: if isManagement();
      allow update: if request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']);
    }

    match /sites/{siteId} {
      allow read: if isAuthenticated();
      allow write: if isManagement();
    }

    match /investigators/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow write: if isManagement();
    }

    match /studies/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow write: if isManagement();
    }

    match /visits/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isAuthenticated() && (isManagement() || isSameSite(request.resource.data.siteId));
      allow update, delete: if isManagement();
    }

    match /assessments/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isAuthenticated() && (isManagement() || isSameSite(request.resource.data.siteId));
      allow update, delete: if isManagement();
    }

    match /delegationLog/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow write: if isManagement();
    }

    match /imports/{docId} {
      allow read, write: if isManagement();
    }

    match /whatIfScenarios/{siteId}/scenarios/{scenarioId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(siteId));
      allow write: if isManagement();
    }

    match /screenFailures/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isAuthenticated() && (isManagement() || isSameSite(request.resource.data.siteId));
      allow update, delete: if isManagement();
    }

    match /enrollmentSnapshots/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isAuthenticated() && (isManagement() || isSameSite(request.resource.data.siteId));
      allow update, delete: if isManagement();
    }

    match /protocolDeviations/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isAuthenticated() && (isManagement() || isSameSite(request.resource.data.siteId));
      allow update, delete: if isManagement();
    }

    match /capacityConfig/{docId} {
      allow read, write: if isManagement();
    }

    match /boardSessions/{docId} {
      allow read: if isAuthenticated() && (isManagement() || isSameSite(resource.data.siteId));
      allow create: if isManagement() && request.resource.data.keys().hasAll(['siteId', 'sessionDate']);
      allow update, delete: if isManagement();
    }

    match /errorLog/{docId} {
      allow read: if isManagement();
      allow create: if isAuthenticated();
    }

    match /auditLog/{docId} {
      allow read: if isManagement();
      allow create: if isAuthenticated()
        || (request.resource.data.action == 'auth.sign_in_failed'
           && request.resource.data.uid == null);
    }
  }
}
